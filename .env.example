# ──────────────────────────────────────────────────────────────────────────────
# TeamSens — Environment Variables Reference
# Copy to .env and fill in your values. NEVER commit .env to git.
# ──────────────────────────────────────────────────────────────────────────────

# ── GCP ───────────────────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=europe-west1

# Service account key (local dev only; on Cloud Run use Workload Identity)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ── Firebase (server-side — matches GCP project) ──────────────────────────────
# (No extra vars needed; uses GOOGLE_APPLICATION_CREDENTIALS / ADC above)

# ── Google OAuth2 (for Calendar/Meet user delegation) ─────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8080/api/v1/auth/callback

# ── Background jobs ───────────────────────────────────────────────────────────
# "cloudtasks" (default) or "asynq"
TASK_DRIVER=asynq

# Cloud Tasks
CLOUDTASKS_QUEUE=email-queue
TASK_HANDLER_URL=https://your-service-url.run.app

# Asynq / Redis (only needed when TASK_DRIVER=asynq)
REDIS_ADDR=redis:6379

# ── SMTP (for email dispatch) ──────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=Your Name <your@gmail.com>

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Next.js (public — baked into the JS bundle at build time) ─────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
